# ====== Supabase ======
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your-service-role-key

# ====== API-Football (via RapidAPI) ======
# Sign up: https://www.api-football.com/  (free tier: 100 req/day)
API_FOOTBALL_KEY=your-api-football-key
# Competition ID for FIFA World Cup. As of 2025-26 it is league=1, season=2026
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# ====== Vercel cron security ======
# Random string. Put the same value in Vercel env. Cron route checks header `x-cron-secret`.
CRON_SECRET=generate-a-random-32-char-string

# ====== App ======
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
